# pnpm config — applies to root + every workspace.
#
# auto-install-peers ensures peerDependencies (e.g. @miden-sdk/miden-sdk
# is a peer of @miden-sdk/react) are auto-installed during `pnpm install`,
# matching yarn classic's lenient behavior. Without this, pnpm's strict
# mode would force every consumer to add the peer themselves.
auto-install-peers=true

# Prefer workspace: protocol when a depended package matches a workspace
# member version range. Keeps cross-package edits hot-reload-able without
# extra `pnpm link` steps.
prefer-workspace-packages=true

# Use pnpm's default isolated node-modules linker (each package gets its
# own dependency closure via .pnpm/ symlinks). Hoisted mode collapses
# everything into a flat node_modules and breaks transitive type packages
# whose declared minimatch range pre-dates our root override (e.g.
# @types/glob@7 imports types removed in minimatch@10). Isolated mode
# keeps each package's declared deps intact, and rollup-plugin-rust /
# wasm-bindgen don't care about the layout.
node-linker=isolated

# Hoist a small set of widely-assumed dev tools to the root so eslint
# plugins, typescript, etc. that get loaded by tools that don't declare
# them still resolve. Keeps the strict-isolation benefits otherwise.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=typescript

# Keep cache writes off for CI where actions/setup-node owns caching.
# Local dev re-uses the global pnpm store, so this only affects CI.
package-import-method=hardlink
