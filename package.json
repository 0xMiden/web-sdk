{
  "name": "@miden-sdk/web-sdk-monorepo",
  "private": true,
  "scripts": {
    "check:sync:react-sdk": "node scripts/check-react-sdk-sync.js",
    "build:web-client": "pnpm --filter @miden-sdk/miden-sdk run build",
    "build:react-sdk": "pnpm --filter @miden-sdk/react run build",
    "build:vite-plugin": "pnpm --filter @miden-sdk/vite-plugin run build",
    "test:react-sdk": "pnpm --filter @miden-sdk/react run test:unit",
    "test:react-sdk:coverage": "pnpm --filter @miden-sdk/react run test:coverage",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.30.1",
    "lefthook": "^1.13.6",
    "lint-staged": "^16.4.0",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": ">=5.0.1",
      "basic-ftp": ">=5.2.0",
      "esbuild": ">=0.25.0",
      "minimatch": ">=10.2.1",
      "qs": ">=6.15.0",
      "rollup": ">=4.59.0",
      "tar": ">=7.5.8",
      "test-exclude>minimatch": "^9.0.0",
      "eslint": "9.33.0",
      "@typescript-eslint/eslint-plugin": "8.39.1",
      "@typescript-eslint/parser": "8.39.1",
      "typescript-eslint": "8.39.1"
    }
  }
}
